{
  "cleanUrls": true,
  "routes": [
    {
      "src": "/sem-for-attorneys/?",
      "status": 301,
      "headers": {
        "Location": "/ppc-for-solicitors"
      }
    },
    {
      "src": "/search-engine-optimisation-for-solicitors-lawyers/?",
      "status": 301,
      "headers": {
        "Location": "/seo-for-solicitors"
      }
    },
    {
      "src": "/details/(.*)",
      "status": 410,
      "headers": {
        "Content-Type": "text/html"
      },
      "dest": "/410.html"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    }
  ]
}